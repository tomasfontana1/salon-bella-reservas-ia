      "name": "Sticky Note"
    },
    {
      "parameters": {
        "jsCode": "let data = $json.body ?? $json;\n\n// Si llega como text/plain, el body puede venir como string\nif (typeof data === \"string\") {\n  try {\n    data = JSON.parse(data);\n  } catch (e) {\n    throw new Error(\"Body inválido (no se pudo parsear JSON)\");\n  }\n}\n\nconst nombre_cliente = (data.nombre_cliente || '').trim();\nconst telefono = (data.telefono || '').replace(/\\D/g, '');\nconst email = (data.email || '').trim().toLowerCase();\nconst servicio = (data.servicio || '').trim();\nconst fecha = (data.fecha || '').trim();\nconst hora = (data.hora || '').trim();\nconst notas = (data.notas || '').trim();\nconst canal_reserva = (data.canal_reserva || 'formulario').trim();\n\nconst errores = [];\n\nif (!nombre_cliente) errores.push('Falta nombre_cliente');\nif (!telefono) errores.push('Falta telefono');\nif (!email) errores.push('Falta email');\nif (!servicio) errores.push('Falta servicio');\nif (!fecha) errores.push('Falta fecha');\nif (!hora) errores.push('Falta hora');\n\nconst emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nif (email && !emailRegex.test(email)) errores.push('Email inválido');\n\nconst horaOk = /^([01]\\d|2[0-3]):(00|30)$/.test(hora);\nif (hora && !horaOk) errores.push('Hora inválida. Debe venir en bloques de 30 min');\n\nconst fecha_hora = (fecha && hora)\n  ? `${fecha}T${hora}:00-03:00`\n  : null;\n\nreturn [\n  {\n    json: {\n      nombre_cliente,\n      telefono,\n      email,\n      servicio,\n      fecha,\n      hora,\n      fecha_hora,\n      notas,\n      canal_reserva,\n      validacion_ok: errores.length === 0,\n      errores\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        176,
        112
      ],
      "id": "e4485c5d-c195-4d23-8d4b-a964b045ebcd",
