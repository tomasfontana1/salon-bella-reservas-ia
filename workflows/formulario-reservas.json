    },
    {
      "parameters": {
        "sendTo": "={{ $node[\"Normalizar y validar entrada\"].json.email || null }}",
        "subject": "=📢 NUEVA RESERVA CONFIRMADA — {{ $node[\"Normalizar y validar entrada\"].json.servicio }} — {{ $node[\"Normalizar y validar entrada\"].json.fecha }} {{ $node[\"Normalizar y validar entrada\"].json.hora }}",
        "message": "=<div style=\"font-family: Arial, sans-serif; line-height: 1.5;\">\n  <h2 style=\"margin:0 0 8px;\">📢 NUEVA RESERVA CONFIRMADA</h2>\n  <p style=\"margin:0 0 16px;\">Se registró una nueva reserva en <b>Sallon Bella</b>.</p>\n\n  <table style=\"border-collapse: collapse; width: 100%; max-width: 520px;\">\n    <tr>\n      <td style=\"padding:8px; border:1px solid #eee;\"><b>💅 Servicio</b></td>\n      <td style=\"padding:8px; border:1px solid #eee;\">{{ $node[\"Normalizar y validar entrada\"].json.servicio }}</td>\n    </tr>\n    <tr>\n      <td style=\"padding:8px; border:1px solid #eee;\"><b>🗓 Fecha</b></td>\n      <td style=\"padding:8px; border:1px solid #eee;\">{{ $node[\"Normalizar y validar entrada\"].json.fecha }}</td>\n    </tr>\n    <tr>\n      <td style=\"padding:8px; border:1px solid #eee;\"><b>🕒 Hora</b></td>\n      <td style=\"padding:8px; border:1px solid #eee;\">{{ $node[\"Normalizar y validar entrada\"].json.hora }}</td>\n    </tr>\n    <tr>\n      <td style=\"padding:8px; border:1px solid #eee;\"><b>👤 Cliente</b></td>\n      <td style=\"padding:8px; border:1px solid #eee;\">{{ $node[\"Normalizar y validar entrada\"].json.nombre_cliente }}</td>\n    </tr>\n    <tr>\n      <td style=\"padding:8px; border:1px solid #eee;\"><b>📞 Teléfono</b></td>\n      <td style=\"padding:8px; border:1px solid #eee;\">{{ $node[\"Normalizar y validar entrada\"].json.telefono }}</td>\n    </tr>\n    <tr>\n      <td style=\"padding:8px; border:1px solid #eee;\"><b>📎 Medio</b></td>\n      <td style=\"padding:8px; border:1px solid #eee;\">{{ $node[\"Normalizar y validar entrada\"].json.canal_reserva }}</td>\n    </tr>\n    <tr>\n      <td style=\"padding:8px; border:1px solid #eee;\"><b>🧾 Estado</b></td>\n      <td style=\"padding:8px; border:1px solid #eee;\">confirmada</td>\n    </tr>\n  </table>\n\n  <p style=\"margin:16px 0 0; color:#666;\">\n    ID de cita: {{ $node[\"Crear cita\"].json.id || $node[\"Crear cita\"].json.cita_id || \"N/A\" }}\n  </p>\n</div>",
        "options": {}
      },
