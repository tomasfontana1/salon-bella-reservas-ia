    {
      "parameters": {
        "jsCode": "const entrada = $node[\"Normalizar y validar entrada\"].json;\nconst servicio = $node[\"Traer servicio\"].json;\n\n// Si vino del branch \"cliente existe\", $json ya es el cliente.\n// Si vino de \"Crear cliente\", también.\nconst cliente = $json;\n\nconst fecha_hora = entrada.fecha_hora;\nconst duracion_minutos = Number(servicio.duracion_minutos || 60);\nconst profesional_id = servicio.profesional_id || \"\";\n\nconst inicio = new Date(fecha_hora);\nconst fecha_fin = new Date(inicio.getTime() + duracion_minutos * 60000).toISOString();\n\nreturn [{\n  json: {\n    cliente_id: cliente.id,\n    servicio_id: servicio.id,\n    profesional_id,\n    fecha_hora,\n    fecha_fin,\n    duracion_minutos,\n    medio_reserva: entrada.canal_reserva,\n    notas: entrada.notas || \"\"\n  }\n}];"
      },
