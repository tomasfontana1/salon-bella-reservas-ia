        "jsCode": "let body = $json.body ?? $json;\n\nif (typeof body === \"string\") {\n  try {\n    body = JSON.parse(body);\n  } catch {\n    body = {};\n  }\n}\n\nconst accion = (body.accion ?? \"\").toString().trim().toLowerCase();\nconst cita_id = (body.cita_id ?? \"\").toString().trim();\nconst nueva_fecha = (body.nueva_fecha ?? \"\").toString().trim();\nconst nueva_hora = (body.nueva_hora ?? \"\").toString().trim();\nconst motivo_cancelacion = (body.motivo_cancelacion ?? \"\").toString().trim();\n\nreturn [{\n  json: {\n    cita_id,\n    accion,\n    nueva_fecha,\n    nueva_hora,\n    motivo_cancelacion\n  }\n}];"
