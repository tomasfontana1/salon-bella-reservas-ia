              "keyName": "estado",
              "condition": "eq",
              "keyValue": "confirmada"
            },
            {
              "keyName": "profesional_id",
              "condition": "eq",
              "keyValue": "={{ $node[\"Calcular ventana reprogramacion\"].json.profesional_id }}"
            },
            {
              "keyName": "fecha_hora",
