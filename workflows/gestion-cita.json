        "jsCode": "const data = $json;\n\nconst fecha_hora = data.fecha_hora;\nif (!fecha_hora) {\n  return [{ json: { ...data, horario_valido: false, motivo_horario: \"Faltan fecha y hora.\" } }];\n}\n\nconst d = new Date(fecha_hora);\nconst day = d.getDay();\nconst minutes = d.getHours() * 60 + d.getMinutes();\n\nif (day === 0) {\n  return [{ json: { ...data, horario_valido: false, motivo_horario: \"El salón no abre los domingos.\" } }];\n}\n\nif (day >= 1 && day <= 5 && (minutes < 540 || minutes > 1200)) {\n  return [{ json: { ...data, horario_valido: false, motivo_horario: \"Atendemos de lunes a viernes de 09:00 a 20:00.\" } }];\n}\n\nif (day === 6 && (minutes < 540 || minutes > 1020)) {\n  return [{ json: { ...data, horario_valido: false, motivo_horario: \"Los sábados atendemos de 09:00 a 17:00.\" } }];\n}\n\nconst mins = d.getMinutes();\nif (![0, 30].includes(mins)) {\n  return [{ json: { ...data, horario_valido: false, motivo_horario: \"Los turnos solo pueden reprogramarse en bloques de 30 minutos.\" } }];\n}\n\nreturn [{ json: { ...data, horario_valido: true, motivo_horario: \"\" } }];"
      },
