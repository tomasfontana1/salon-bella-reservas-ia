    {
      "parameters": {
        "jsCode": "const cita = $node[\"Buscar cita\"].json || {};\nconst entrada = $node[\"Parsear entrada gestion\"].json || {};\nconst servicio = $node[\"Traer servicio cita\"].json || {};\n\nconst nueva_fecha = entrada.nueva_fecha;\nconst nueva_hora = entrada.nueva_hora;\n\nconst fecha_hora = (nueva_fecha && nueva_hora)\n  ? `${nueva_fecha}T${nueva_hora}:00-03:00`\n  : \"\";\n\nconst duracion = Number(\n  cita.duracion_minutos ||\n  servicio.duracion_minutos ||\n  60\n);\n\nconst profesional_id =\n  cita.profesional_id ||\n  servicio.profesional_id ||\n  \"\";\n\nif (!fecha_hora || !profesional_id) {\n  return [{\n    json: {\n      ...cita,\n      ...entrada,\n      profesional_id,\n      fecha_hora,\n      fecha_fin: \"\",\n      duracion_minutos: duracion\n    }\n  }];\n}\n\nconst inicio = new Date(fecha_hora);\nconst fin = new Date(inicio.getTime() + duracion * 60000);\n\nreturn [{\n  json: {\n    ...cita,\n    ...entrada,\n    profesional_id,\n    fecha_hora,\n    fecha_fin: fin.toISOString(),\n    duracion_minutos: duracion\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        -96
      ],
      "id": "c7c66317-006e-4707-8dda-84d04473eaf6",
      "name": "Calcular ventana reprogramacion"
    },
