    {
      "parameters": {
        "jsCode": "const entrada = (() => {\n  try {\n    return $node[\"Parsear entrada gestion\"].json || {};\n  } catch {\n    return {};\n  }\n})();\n\nconst cita = (() => {\n  try {\n    return $node[\"Buscar cita\"].json || {};\n  } catch {\n    return {};\n  }\n})();\n\nconst validacionHorario = (() => {\n  try {\n    return $node[\"Validar horario reprogramacion\"].json || null;\n  } catch {\n    return null;\n  }\n})();\n\nconst cancelada = (() => {\n  try {\n    return $node[\"Cancelar cita\"].json || null;\n  } catch {\n    return null;\n  }\n})();\n\nconst completada = (() => {\n  try {\n    return $node[\"Completar cita\"].json || null;\n  } catch {\n    return null;\n  }\n})();\n\nconst reprogramada = (() => {\n  try {\n    return $node[\"Actualizar cita reprogramada\"].json || null;\n  } catch {\n    return null;\n  }\n})();\n\nconst nuevaVentana = (() => {\n  try {\n    return $node[\"Calcular ventana reprogramacion\"].json || null;\n  } catch {\n    return null;\n  }\n})();\n\nconst accion = (entrada.accion || \"\").toString().trim().toLowerCase();\n\nfunction formatFechaHora(fechaHora) {\n  if (!fechaHora) return { fecha: \"\", hora: \"\" };\n\n  const d = new Date(fechaHora);\n  if (Number.isNaN(d.getTime())) return { fecha: \"\", hora: \"\" };\n\n  const fecha = d.toLocaleDateString(\"es-AR\", {\n    timeZone: \"America/Argentina/Buenos_Aires\",\n    year: \"numeric\",\n    month: \"2-digit\",\n    day: \"2-digit\",\n  });\n\n  const hora = d.toLocaleTimeString(\"es-AR\", {\n    timeZone: \"America/Argentina/Buenos_Aires\",\n    hour: \"2-digit\",\n    minute: \"2-digit\",\n    hour12: false,\n  });\n\n  return { fecha, hora };\n}\n\n// No existe cita\nif (!cita.id) {\n  return [{\n    json: {\n      ok: false,\n      respuesta: \"No encontré la cita indicada.\"\n    }\n  }];\n}\n\n// Estado no gestionable\nif (cita.estado && cita.estado !== \"confirmada\") {\n  return [{\n    json: {\n      ok: false,\n      respuesta: `La cita no se puede gestionar porque está en estado \"${cita.estado}\".`\n    }\n  }];\n}\n\n// Acción inválida\nif (![\"cancelar\", \"reprogramar\", \"completar\"].includes(accion)) {\n  return [{\n    json: {\n      ok: false,\n      respuesta: \"La acción solicitada no es válida.\"\n    }\n  }];\n}\n\n// Cancelar\nif (accion === \"cancelar\") {\n  if (cancelada && (cancelada.id || cancelada.estado === \"cancelada\")) {\n    return [{\n      json: {\n        ok: true,\n        respuesta: \"La cita fue cancelada correctamente.\"\n      }\n    }];\n  }\n\n  return [{\n    json: {\n      ok: false,\n      respuesta: \"No pude cancelar la cita. Intentá nuevamente.\"\n    }\n  }];\n}\n\n// Completar\nif (accion === \"completar\") {\n  if (completada && (completada.id || completada.estado === \"completada\")) {\n    return [{\n      json: {\n        ok: true,\n        respuesta: \"La cita fue marcada como completada.\"\n      }\n    }];\n  }\n\n  return [{\n    json: {\n      ok: false,\n      respuesta: \"No pude completar la cita. Intentá nuevamente.\"\n    }\n  }];\n}\n\n// Reprogramar\nif (accion === \"reprogramar\") {\n  if (validacionHorario && validacionHorario.horario_valido === false) {\n    return [{\n      json: {\n        ok: false,\n        respuesta: validacionHorario.motivo_horario || \"La nueva fecha u hora no es válida.\"\n      }\n    }];\n  }\n\n  if (!reprogramada || (!reprogramada.id && !reprogramada.fecha_hora)) {\n    return [{\n      json: {\n        ok: false,\n        respuesta: \"No pude reprogramar la cita. Es posible que ese horario ya esté ocupado o que haya un error en los datos.\"\n      }\n    }];\n  }\n\n  const fh = nuevaVentana?.fecha_hora || reprogramada?.fecha_hora || \"\";\n  const { fecha, hora } = formatFechaHora(fh);\n\n  return [{\n    json: {\n      ok: true,\n      respuesta: `La cita fue reprogramada correctamente para el ${fecha} a las ${hora}.`\n    }\n  }];\n}\n\n// Fallback\nreturn [{\n  json: {\n    ok: false,\n    respuesta: \"No pude procesar la solicitud.\"\n  }\n}];"
      },
