      "id": "0fcfb646-5a8d-4744-9f65-8ef6f24652b8",
      "name": "Traer cita",
      "alwaysOutputData": true,
      "credentials": {
        "REDACTED": "Configurar credenciales propias en n8n"
      }
    },
    {
      "parameters": {
        "jsCode": "const cita = $node[\"Procesar citas (batch 1)\"].json;\nconst cliente = $node[\"Traer cliente\"].json;\nconst servicio = $node[\"Traer servicio\"].json;\n\nconst to = (cliente.email || \"\").trim();\n\n// tipo de recordatorio\nconst reminderType = (cita.reminder_type || \"24h\").toString();\nconst prefix = reminderType === \"2h\"\n  ? \"⏰ Recordatorio (2 horas)\"\n  : \"⏰ Recordatorio (24 horas)\";\n\n// fecha/hora\nconst fechaHora = new Date(cita.fecha_hora);\nconst fechaStr = fechaHora.toLocaleDateString(\"es-AR\", {\n  timeZone: \"America/Argentina/Buenos_Aires\",\n  year: \"numeric\",\n  month: \"2-digit\",\n  day: \"2-digit\"\n});\n\nconst horaStr = fechaHora.toLocaleTimeString(\"es-AR\", {\n  timeZone: \"America/Argentina/Buenos_Aires\",\n  hour: \"2-digit\",\n  minute: \"2-digit\"\n});\n\nconst subject = `${prefix} — ${servicio.nombre} — ${fechaStr} ${horaStr}`;\n\nconst html = `\n<div style=\"font-family: Arial, sans-serif; line-height: 1.5;\">\n  <h2 style=\"margin:0 0 8px;\">${prefix}</h2>\n  <p style=\"margin:0 0 16px;\">\n    Hola <b>${cliente.nombre_completo}</b>, te recordamos tu turno en <b>Sallon Bella</b>.\n  </p>\n\n  <table style=\"border-collapse: collapse; width: 100%; max-width: 520px;\">\n    <tr>\n      <td style=\"padding:8px; border:1px solid #eee;\"><b>💅 Servicio</b></td>\n      <td style=\"padding:8px; border:1px solid #eee;\">${servicio.nombre}</td>\n    </tr>\n    <tr>\n      <td style=\"padding:8px; border:1px solid #eee;\"><b>🗓 Fecha</b></td>\n      <td style=\"padding:8px; border:1px solid #eee;\">${fechaStr}</td>\n    </tr>\n    <tr>\n      <td style=\"padding:8px; border:1px solid #eee;\"><b>🕒 Hora</b></td>\n      <td style=\"padding:8px; border:1px solid #eee;\">${horaStr}</td>\n    </tr>\n    <tr>\n      <td style=\"padding:8px; border:1px solid #eee;\"><b>📍 Lugar</b></td>\n      <td style=\"padding:8px; border:1px solid #eee;\">Sallon Bella</td>\n    </tr>\n  </table>\n\n  <p style=\"margin:16px 0 0; color:#666;\">\n    Si necesitás reprogramar o cancelar, respondé este mail o comunicate por WhatsApp/Instagram.\n  </p>\n\n  <p style=\"margin:8px 0 0; color:#999; font-size: 12px;\">\n    ID de cita: ${cita.id}\n  </p>\n</div>\n`;\n\nreturn [{\n  json: {\n    to,\n    subject,\n    html,\n    cita_id: cita.id,\n    reminder_type: reminderType,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
