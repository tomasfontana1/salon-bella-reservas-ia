    {
      "parameters": {
        "jsCode": "const now = Date.now();\n\nconst window24Start = now + (24 * 60 - 15) * 60 * 1000;\nconst window24End   = now + (24 * 60 + 15) * 60 * 1000;\n\nconst window2Start  = now + (2 * 60 - 15) * 60 * 1000;\nconst window2End    = now + (2 * 60 + 15) * 60 * 1000;\n\nconst out = [];\n\nfor (const it of $input.all()) {\n  const cita = it.json;\n\n  if (!cita.fecha_hora) continue;\n  if (cita.estado !== \"confirmada\") continue;\n\n  const t = new Date(cita.fecha_hora).getTime();\n  if (Number.isNaN(t)) continue;\n\n  // defensa extra: si ya pasó, no la proceses\n  if (t <= now) continue;\n\n  if (!cita.recordatorio_24h_enviado && t >= window24Start && t <= window24End) {\n    out.push({ json: { ...cita, reminder_type: \"24h\" } });\n    continue;\n  }\n\n  if (!cita.recordatorio_2h_enviado && t >= window2Start && t <= window2End) {\n    out.push({ json: { ...cita, reminder_type: \"2h\" } });\n    continue;\n  }\n}\n\nreturn out;"
      },
